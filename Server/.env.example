# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Database selection: mysql | postgres | mongodb
DB_TYPE=mysql

# MySQL / Postgres (Sequelize)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=leafandlume
DB_USER=root
DB_PASSWORD=

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/leafandlume

# JWT
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
