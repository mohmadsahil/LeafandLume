# Public site URL (used by SEO/sitemap). Must be a fully-qualified URL with protocol.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public site name shown in metadata
NEXT_PUBLIC_SITE_NAME=Leaf and Lume

# Public API base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Server-only secrets (never prefix with NEXT_PUBLIC_)
# API_SECRET=your-secret-here
